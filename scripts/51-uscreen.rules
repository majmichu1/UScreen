# UScreen - Auto-detect Android tablet, start uscreen daemon
# Samsung devices (04e8)
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="04e8", ATTR{idProduct}=="6860", TAG+="systemd", ENV{SYSTEMD_USER_WANTS}="uscreen.service"
ACTION=="remove", SUBSYSTEM=="usb", ATTR{idVendor}=="04e8", ATTR{idProduct}=="6860", RUN+="/usr/bin/systemctl --user stop uscreen.service"
